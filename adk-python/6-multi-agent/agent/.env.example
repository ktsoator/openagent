# Copy this file to .env and replace the placeholder values.

# Default model used when calling create_model() without arguments.
MODEL_NAME=openai/your-model-name

# OpenAI-compatible backend
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_API_BASE=https://your-openai-compatible-base/v1

# Anthropic-compatible backend
ANTHROPIC_API_KEY=your_anthropic_compatible_api_key
ANTHROPIC_API_BASE=https://your-anthropic-compatible-base
